{
  "dashboard": {
    "title": "Jenkins CI/CD Monitoring",
    "uid": "jenkins-cicd-monitoring",
    "tags": ["jenkins", "cicd", "builds"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Jenkins Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "jenkins_up{job=\"jenkins\"}",
            "legendFormat": "Jenkins Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Available Executors",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "targets": [
          {
            "expr": "jenkins_executor_available_value{job=\"jenkins\"}",
            "legendFormat": "Available Executors"
          }
        ]
      },
      {
        "id": 3,
        "title": "Queue Size",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "jenkins_queue_size{job=\"jenkins\"}",
            "legendFormat": "Queue Size"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Online Nodes",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "count(jenkins_node_online_value{job=\"jenkins\"} == 1)",
            "legendFormat": "Online Nodes"
          }
        ]
      },
      {
        "id": 5,
        "title": "Build Success Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(jenkins_job_build_success_total[1h])) / (sum(rate(jenkins_job_build_success_total[1h])) + sum(rate(jenkins_job_build_failure_total[1h]))) * 100",
            "legendFormat": "Success Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 80},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Total Builds (1h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(jenkins_job_build_success_total[1h])) + sum(increase(jenkins_job_build_failure_total[1h]))",
            "legendFormat": "Total Builds"
          }
        ]
      },
      {
        "id": 7,
        "title": "Build Duration Trend",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "avg(jenkins_builds_last_build_duration_milliseconds) by (job) / 1000",
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "Build Results",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(jenkins_job_build_success_total[5m])) by (job)",
            "legendFormat": "{{job}} - Success"
          },
          {
            "expr": "sum(rate(jenkins_job_build_failure_total[5m])) by (job)",
            "legendFormat": "{{job}} - Failure"
          }
        ]
      },
      {
        "id": 9,
        "title": "Queue Wait Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "avg(jenkins_queue_waiting_time_seconds) by (job)",
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 10,
        "title": "Executor Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "jenkins_executor_count_value{job=\"jenkins\"} - jenkins_executor_available_value{job=\"jenkins\"}",
            "legendFormat": "Busy Executors"
          },
          {
            "expr": "jenkins_executor_available_value{job=\"jenkins\"}",
            "legendFormat": "Available Executors"
          }
        ]
      },
      {
        "id": 11,
        "title": "Build Failure Rate by Job",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "sum(rate(jenkins_job_build_failure_total[1h])) by (job) / (sum(rate(jenkins_job_build_success_total[1h])) by (job) + sum(rate(jenkins_job_build_failure_total[1h])) by (job)) * 100",
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            }
          }
        }
      },
      {
        "id": 12,
        "title": "Node Status",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "jenkins_node_online_value{job=\"jenkins\"}",
            "legendFormat": "{{node}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 13,
        "title": "Build Count by Job",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "sum(increase(jenkins_job_build_success_total[1h])) by (job)",
            "legendFormat": "{{job}} - Success"
          },
          {
            "expr": "sum(increase(jenkins_job_build_failure_total[1h])) by (job)",
            "legendFormat": "{{job}} - Failure"
          }
        ]
      },
      {
        "id": 14,
        "title": "Queue Size Trend",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "jenkins_queue_size{job=\"jenkins\"}",
            "legendFormat": "Queue Size"
          }
        ]
      },
      {
        "id": 15,
        "title": "Job Last Build Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
        "targets": [
          {
            "expr": "jenkins_builds_last_build_result_ordinal",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "job": "Job Name",
                "jenkins_builds_last_build_result_ordinal": "Last Build Status"
              }
            }
          }
        ]
      }
    ]
  }
}